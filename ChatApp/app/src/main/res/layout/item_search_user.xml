<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <androidx.cardview.widget.CardView
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardCornerRadius="24dp"
        app:cardBackgroundColor="#1A1E29"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/ivSearchAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/rounded_account_circle_24"
            android:scaleType="centerCrop"
            android:importantForAccessibility="no" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvSearchUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:text="Username"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#E2E8F0"
        android:fontFamily="sans-serif-medium" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnAddFriend"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Add Friend"
        android:textColor="#0B0F19"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_cyan_button"
        android:paddingHorizontal="16dp" />

</LinearLayout>




