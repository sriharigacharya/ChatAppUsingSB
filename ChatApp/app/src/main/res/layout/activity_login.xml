<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0B0F19"
    android:fitsSystemWindows="true"> <!-- 60% Deep Obsidian Blue Background -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Top Spacer to push content gracefully down on larger screens -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- App Logo Icon / Branding Element -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/ic_launcher_background"
            android:src="@drawable/ic_launcher_foreground"
            android:importantForAccessibility="no" />

        <!-- Screen Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SecureChat"
            android:textColor="#E2E8F0"
        android:textSize="26sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your credentials to decrypt session."
            android:textColor="#64748B"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"/>

        <!-- Username Input Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input_field">

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Username"
                android:textColor="#E2E8F0"
                android:textColorHint="#64748B"
                android:inputType="text"
                android:background="@null"
                android:textSize="16sp"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Password Input Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_input_field">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Password"
                android:textColor="#E2E8F0"
                android:textColorHint="#64748B"
                android:inputType="textPassword"
                android:background="@null"
                android:textSize="16sp"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- Login Button (Electric Cyan) -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sign In"
            android:textColor="#0B0F19"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_cyan_button"
        android:elevation="4dp"
        android:layout_marginBottom="24dp"/>

        <!-- Register Link -->
        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an account? Register here."
            android:textColor="#38BDF8"
        android:textSize="14sp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground"/>

        <!-- Bottom Spacer -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.5" />

    </LinearLayout>
</ScrollView>



